{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "Contact form submissions",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "phone": { "type": "string", "description": "Phone number" },
        "message": { "type": "string", "description": "Message or needs" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Submission timestamp" },
        "uid": { "type": "string", "description": "User ID if logged in" }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Collection of leads"
    }
  }
}
